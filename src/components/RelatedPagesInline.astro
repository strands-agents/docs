---
/**
 * "See also" pill row at the end of the article body, above Starlight's
 * Prev/Next pagination. Renders as outlined pills that wrap to fit content.
 * No box, no border, no fill on the container — only the pills themselves
 * have outlines, so this doesn't compete with the Prev/Next cards below.
 */
import { getCollection } from 'astro:content'
import { humanRelatedUserGuideFor } from '../util/related-docs'
import { pathWithBase } from '../util/links'

const { starlightRoute } = Astro.locals
const entry = starlightRoute.entry

// Non-docs routes (blog pages, StarlightPage splashes) flow through
// MarkdownContent too — short-circuit before calling into the util.
const related = entry.collection === 'docs'
  ? humanRelatedUserGuideFor(entry, await getCollection('docs'))
  : []
---

{related.length > 0 && (
  <aside class="related-pills" aria-label="Related pages">
    <div class="related-pills__label">Related</div>
    <ul class="related-pills__list">
      {related.map((link) => (
        <li class="related-pills__item">
          <a class="related-pills__pill" href={pathWithBase(`/${link.slug}/`)}>
            {link.title}
          </a>
        </li>
      ))}
    </ul>
  </aside>
)}

<style>
  .related-pills {
    margin-top: 2.5rem;
  }

  .related-pills__label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
    margin-bottom: 0.625rem;
  }

  .related-pills__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .related-pills__item {
    margin: 0;
    padding: 0;
  }

  .related-pills__pill {
    display: inline-block;
    padding: 0.375rem 0.875rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 999px;
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.3;
    color: var(--sl-color-text);
    text-decoration: none;
    background: transparent;
    transition: border-color 0.15s ease, color 0.15s ease, background-color 0.15s ease;
  }

  .related-pills__pill:hover {
    border-color: var(--sl-color-text-accent);
    color: var(--sl-color-text-accent);
    background-color: var(--sl-color-gray-7, var(--sl-color-gray-6));
  }

  /* Override Starlight's default list styling for sl-markdown-content */
  :global(.sl-markdown-content) .related-pills__list {
    padding-left: 0;
  }
  :global(.sl-markdown-content) .related-pills__item::before {
    content: none;
  }
</style>
