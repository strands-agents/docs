---
/**
 * Global Python/TypeScript language toggle for the site header.
 *
 * Reads and writes the same localStorage key used by AutoSyncTabs
 * (starlight-synced-tabs__jarkqt) so the header toggle and inline
 * code tabs stay in sync.
 */
---

<language-toggle class="language-toggle" role="radiogroup" aria-label="Preferred language">
  <button
    class="lang-option"
    role="radio"
    aria-checked="true"
    data-lang="Python"
  >
    <svg class="lang-icon" viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
      <path fill="currentColor" d="M11.914 0C5.82 0 6.2 2.656 6.2 2.656l.007 2.752h5.814v.826H3.9S0 5.789 0 11.969c0 6.18 3.403 5.96 3.403 5.96h2.03v-2.867s-.109-3.42 3.35-3.42h5.766s3.24.052 3.24-3.148V3.202S18.28 0 11.914 0zM8.708 1.85a1.06 1.06 0 110 2.12 1.06 1.06 0 010-2.12z"/>
      <path fill="currentColor" d="M12.086 24c6.094 0 5.714-2.656 5.714-2.656l-.007-2.752H11.98v-.826h8.121S24 18.211 24 12.031c0-6.18-3.403-5.96-3.403-5.96h-2.03v2.867s.109 3.42-3.35 3.42H9.451s-3.24-.052-3.24 3.148v5.292S5.72 24 12.086 24zm3.206-1.85a1.06 1.06 0 110-2.12 1.06 1.06 0 010 2.12z"/>
    </svg>
    Python
  </button>
  <button
    class="lang-option"
    role="radio"
    aria-checked="false"
    data-lang="TypeScript"
  >
    <svg class="lang-icon" viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
      <path fill="currentColor" d="M0 12v12h24V0H0zm19.341-.956c.61.152 1.074.423 1.501.865.221.236.549.666.575.77.008.03-1.036.73-1.668 1.123-.023.015-.115-.084-.217-.236-.31-.45-.633-.644-1.128-.678-.728-.05-1.196.331-1.192.967a.88.88 0 00.102.45c.16.331.458.53 1.39.933 1.719.74 2.454 1.227 2.911 1.92.509.773.625 2.008.278 2.926-.38 1.023-1.325 1.716-2.655 1.95-.41.073-1.382.062-1.828-.018-.964-.172-1.878-.648-2.442-1.273-.221-.243-.652-.88-.625-.925.011-.016.11-.077.22-.141l.89-.514.69-.4.145.213c.201.31.643.731.91.872.766.404 1.817.347 2.335-.118a.883.883 0 00.313-.72c0-.278-.035-.4-.18-.61-.186-.266-.567-.49-1.649-.96-1.238-.533-1.771-.864-2.259-1.39a3.165 3.165 0 01-.659-1.2c-.091-.364-.114-1.27-.042-1.635.31-1.554 1.534-2.64 3.202-2.84.434-.05 1.443-.01 1.872.074zm-5.66 1.077l.007.983H10.15v8.876H7.787V12.104H4.25v-.963c0-.534.011-.98.026-.99.012-.016 2.125-.023 4.694-.018l4.665.011z"/>
    </svg>
    TypeScript
  </button>
</language-toggle>

<style>
  .language-toggle {
    display: inline-flex;
    align-items: center;
    background: var(--sl-color-gray-6);
    border-radius: 0.375rem;
    padding: 0.125rem;
    gap: 0.125rem;
  }

  .lang-option {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.5rem;
    border: none;
    border-radius: 0.25rem;
    background: transparent;
    color: var(--sl-color-gray-2);
    font-size: 0.75rem;
    font-weight: 500;
    font-family: var(--sl-font);
    cursor: pointer;
    transition: all 0.15s ease;
    white-space: nowrap;
    line-height: 1;
  }

  .lang-option:hover {
    color: var(--sl-color-white);
    background: var(--sl-color-gray-5);
  }

  .lang-option[aria-checked='true'] {
    background: var(--strands-logo-green, #00cc5f);
    color: #0E0E0E;
  }

  .lang-option[aria-checked='true']:hover {
    background: var(--strands-green-hover, #00D965);
    color: #0E0E0E;
  }

  .lang-icon {
    flex-shrink: 0;
  }

  :global([data-theme='light']) .lang-option {
    color: var(--sl-color-gray-3);
  }

  :global([data-theme='light']) .lang-option:hover {
    color: var(--sl-color-gray-1);
    background: var(--sl-color-gray-5);
  }

  :global([data-theme='light']) .lang-option[aria-checked='true'] {
    background: var(--strands-logo-green, #00cc5f);
    color: #0E0E0E;
  }
</style>

<script is:inline>
  (function () {
    var STORAGE_KEY = 'starlight-synced-tabs__jarkqt';
    var DEFAULT_LANG = 'Python';

    // Nav links whose href should swap based on language preference.
    // Each entry: [navLinkLabel, pythonHref, typescriptHref]
    var LANG_AWARE_LINKS = [
      ['Docs', '/docs/user-guide/quickstart/python/', '/docs/user-guide/quickstart/typescript/'],
      ['API Reference', '/docs/api/python/', '/docs/api/typescript/']
    ];

    // Path prefixes where /python/ <-> /typescript/ swapping is valid.
    // If the current page is under one of these and the user toggles language,
    // we navigate to the counterpart page.
    var PAIRED_PATH_PREFIXES = [
      '/docs/user-guide/quickstart/',
      '/docs/api/',
      '/docs/user-guide/deploy/deploy_to_bedrock_agentcore/',
      '/docs/user-guide/deploy/deploy_to_docker/'
    ];

    function getPreference() {
      try {
        return localStorage.getItem(STORAGE_KEY) || DEFAULT_LANG;
      } catch {
        return DEFAULT_LANG;
      }
    }

    function setPreference(lang) {
      try {
        localStorage.setItem(STORAGE_KEY, lang);
      } catch {}
    }

    function langSlug(lang) {
      return lang === 'Python' ? 'python' : 'typescript';
    }

    function otherLangSlug(lang) {
      return lang === 'Python' ? 'typescript' : 'python';
    }

    /** Rewrite nav link hrefs to match the current language preference. */
    function updateNavLinks(lang) {
      var slug = langSlug(lang);
      document.querySelectorAll('.nav-tab, .mobile-nav-link').forEach(function (link) {
        var label = link.textContent.trim();
        for (var i = 0; i < LANG_AWARE_LINKS.length; i++) {
          if (label === LANG_AWARE_LINKS[i][0]) {
            var href = lang === 'Python' ? LANG_AWARE_LINKS[i][1] : LANG_AWARE_LINKS[i][2];
            // Preserve any base path prefix already on the link
            var currentHref = link.getAttribute('href') || '';
            var base = '';
            for (var j = 0; j < LANG_AWARE_LINKS[i].length; j++) {
              if (j === 0) continue;
              var candidate = LANG_AWARE_LINKS[i][j];
              var idx = currentHref.indexOf(candidate);
              if (idx > 0) {
                base = currentHref.substring(0, idx);
                break;
              }
            }
            link.setAttribute('href', base + href);
            break;
          }
        }
      });
    }

    /**
     * If the current page is a paired page, return the counterpart URL
     * for the given language. Returns null if no swap applies.
     */
    function getPairedUrl(lang) {
      var path = window.location.pathname;
      var target = langSlug(lang);
      var other = otherLangSlug(lang);

      for (var i = 0; i < PAIRED_PATH_PREFIXES.length; i++) {
        var prefix = PAIRED_PATH_PREFIXES[i];
        // Also match with a base path prefix (e.g., /latest/docs/...)
        if (path.indexOf(prefix) !== -1) {
          // Check if the current path contains the OTHER language slug
          // e.g., we're on /quickstart/python/ and switching to TypeScript
          var regex = new RegExp('/' + other + '(/|$)');
          if (regex.test(path)) {
            return path.replace('/' + other + '/', '/' + target + '/');
          }
          break;
        }
      }
      return null;
    }

    /** Sync all visible Starlight tab groups to match the selected language. */
    function syncStarlightTabs(lang) {
      document.querySelectorAll('starlight-tabs').forEach(function (tabGroup) {
        var panels = tabGroup.querySelectorAll('[role="tabpanel"]');
        var tabs = tabGroup.querySelectorAll('[role="tab"]');
        tabs.forEach(function (tab, i) {
          if (tab.textContent.trim() === lang) {
            tab.setAttribute('aria-selected', 'true');
            tab.setAttribute('tabindex', '0');
            if (panels[i]) panels[i].hidden = false;
          } else {
            tab.setAttribute('aria-selected', 'false');
            tab.setAttribute('tabindex', '-1');
            if (panels[i]) panels[i].hidden = true;
          }
        });
      });
    }

    function updateToggle(lang) {
      document.querySelectorAll('language-toggle .lang-option').forEach(function (btn) {
        btn.setAttribute('aria-checked', btn.dataset.lang === lang ? 'true' : 'false');
      });
    }

    /** Full UI sync: toggle state + nav links + inline tabs. */
    function syncAll(lang) {
      updateToggle(lang);
      updateNavLinks(lang);
      syncStarlightTabs(lang);
    }

    // Restore on page load
    var current = getPreference();
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () { syncAll(current); });
    } else {
      syncAll(current);
    }

    // Handle toggle clicks
    document.addEventListener('click', function (e) {
      var btn = e.target.closest('.lang-option');
      if (!btn) return;
      var lang = btn.dataset.lang;
      if (!lang) return;
      setPreference(lang);
      syncAll(lang);

      // Navigate to paired page if one exists
      var paired = getPairedUrl(lang);
      if (paired) {
        window.location.href = paired;
      }
    });

    // Listen for storage changes from other tabs/windows
    window.addEventListener('storage', function (e) {
      if (e.key === STORAGE_KEY && e.newValue) {
        syncAll(e.newValue);
      }
    });
  })();
</script>
