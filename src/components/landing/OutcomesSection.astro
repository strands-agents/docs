---
/**
 * "Deliver high quality outcomes" — progressive intervention: deny → guide.
 * Bridges from "See what's happening" (observability) to "100% Stat" (proof).
 * Two code blocks: hook (hard deny) → steering handler (corrective feedback).
 */
import CodeBlock from './CodeBlock.astro'

const denyCode = `from strands import Agent
from strands.hooks import BeforeToolCallEvent

def read_only_guard(event: BeforeToolCallEvent):
    """Block all write operations. This agent is read-only."""
    if event.tool_use["name"] == "query_database":
        sql = str(event.tool_use["input"].get("query", "")).upper()
        if any(kw in sql for kw in ["INSERT", "UPDATE", "DELETE", "DROP"]):
            event.cancel_tool = "This agent has read-only access."

agent = Agent(tools=[query_database], hooks=[read_only_guard])`

const guideCode = `from strands.vended_plugins.steering import (
    SteeringHandler, Guide, Proceed,
)

class QueryQualityPolicy(SteeringHandler):
    async def steer_before_tool(self, *, agent, tool_use, **kwargs):
        sql = str(tool_use["input"].get("query", "")).upper()
        if "SELECT" in sql and "WHERE" not in sql:
            return Guide(
                reason="Query selects all rows. Add a WHERE clause "
                "to scope results, and LIMIT to cap response size."
            )
        if sql.count("JOIN") > 3:
            return Guide(
                reason="Query has 4+ joins. Simplify by breaking "
                "into smaller queries or checking the schema."
            )
        return Proceed(reason="Query looks good.")

agent = Agent(tools=[query_database], plugins=[QueryQualityPolicy()])`
---

<section class="outcomes-section">
  <div class="outcomes-inner">
    <h2 class="section-heading">Recover from mistakes</h2>
    <p class="section-description">
      Agents make mistakes. Strands agents recover. Hard guardrails block what should never happen. Corrective feedback teaches the agent to do better.
    </p>
    <div class="outcomes-code">
      <CodeBlock code={denyCode} filename="read_only_agent.py" />
    </div>
    <p class="section-annotation">
      Two policies, one agent. Block what shouldn't happen. Guide what should happen better.
    </p>
    <div class="outcomes-code">
      <CodeBlock code={guideCode} filename="query_quality_policy.py" />
    </div>
  </div>
</section>

