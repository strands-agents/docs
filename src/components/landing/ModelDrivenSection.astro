---
/**
 * "Build your way" section — progressive complexity from working defaults.
 */
import CodeBlock from './CodeBlock.astro'

const agentCode = `from strands import Agent, tool

@tool
def search_logs(query: str, hours: int = 24) -> list:
    """Search application logs by keyword."""
    return log_api.search(query, hours)

agent = Agent(
    tools=[search_logs],
    max_turns=30,
)

agent("Find all timeout errors from the last 6 hours")`

const swapCode = `from strands.agent.conversation_manager import SummarizingConversationManager

# Same agent, now with summarization for long sessions.
agent = Agent(
    tools=[search_logs],
    max_turns=30,
    conversation_manager=SummarizingConversationManager(),
)`
---

<section class="model-driven-section">
  <div class="model-driven-inner">
    <h2 class="section-heading">Build your way</h2>
    <p class="section-description">
      Context management, execution limits, and observability by default. Add tools when you need them, swap backends when you scale. No rewrites.
    </p>
    <div class="model-driven-code">
      <CodeBlock code={agentCode} filename="agent.py" />
    </div>
    <p class="section-annotation">
      Same agent, one swap. No rewrites.
    </p>
    <div class="model-driven-code">
      <CodeBlock code={swapCode} filename="agent_with_context.py" />
    </div>
  </div>
</section>

<style>
  .model-driven-section {
    padding: 5rem 2rem;
    display: flex;
    justify-content: center;
  }

  .model-driven-inner {
    max-width: 800px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .section-heading {
    font-family: 'Figtree', sans-serif;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 600;
    color: var(--sl-color-white);
    text-align: center;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .section-description {
    font-family: 'Figtree', sans-serif;
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--sl-color-gray-2);
    text-align: center;
    max-width: 640px;
    margin: 0;
  }

  .section-description em {
    color: var(--sl-color-white);
    font-style: normal;
    font-weight: 500;
  }

  .model-driven-code {
    width: 100%;
    margin-top: 0.5rem;
  }

  .section-annotation {
    font-family: 'Figtree', sans-serif;
    font-size: 0.9rem;
    color: var(--sl-color-gray-4);
    text-align: center;
    margin: 0;
  }

  .section-annotation code {
    font-family: ui-monospace, 'SF Mono', 'Cascadia Code', monospace;
    font-size: 0.85em;
    color: var(--sl-color-gray-3);
    background: rgba(255, 255, 255, 0.05);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  :global([data-theme='light']) .section-annotation code {
    background: rgba(0, 0, 0, 0.05);
    color: var(--sl-color-gray-2);
  }

  @media (max-width: 768px) {
    .model-driven-section {
      padding: 3rem 1.5rem;
    }
  }
</style>
