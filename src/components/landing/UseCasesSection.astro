---
/**
 * Three use case sections: Automate Workflows, Build AI Assistants, Build Research Agents.
 * Each has a heading, description, and code sample.
 */
import CodeBlock from './CodeBlock.astro'

const workflowCode = `from strands import Agent, tool

@tool
def classify_lead(email: str, company: str) -> dict:
    """Score and classify an inbound lead."""
    firmographics = crm.lookup(company)
    return {
        "score": compute_icp_score(firmographics),
        "segment": firmographics["industry"],
    }

@tool
def route_to_rep(lead_id: str, region: str) -> str:
    """Assign a lead to the right sales rep."""
    rep = crm.get_rep_for_region(region)
    crm.assign(lead_id, rep)
    return f"Assigned to {rep}"

agent = Agent(
    tools=[classify_lead, route_to_rep],
)

agent("New lead: jane@acme.com at Acme Corp, US-West")`

const assistantCode = `from strands import Agent, tool
from strands.tools.mcp import MCPClient
from mcp import stdio_client, StdioServerParameters

kb = MCPClient(lambda: stdio_client(
    StdioServerParameters(command="uvx", args=["kb-server"])
))

@tool
def escalate(reason: str, conversation_id: str) -> str:
    """Hand off to a human agent with full context."""
    return support_api.create_ticket(reason, conversation_id)

agent = Agent(
    system_prompt="You are a support assistant. Use the knowledge "
    "base to answer questions. Escalate billing issues to a human.",
    tools=[kb, escalate],
)

agent("How do I upgrade my plan?")`

const researchCode = `from strands import Agent, tool
from strands_tools import http_request
from pathlib import Path

@tool
def save_report(title: str, content: str) -> str:
    """Save a research report to disk."""
    Path(f"reports/{title}.md").write_text(content)
    return f"Saved {title}.md"

agent = Agent(
    system_prompt="You are a research assistant. Search the web, "
    "synthesize findings, and save a report with source citations.",
    tools=[http_request, save_report],
    max_turns=30,
)

agent("Research AI agent sandboxing and write a comparison report")`

const useCases = [
  {
    title: 'Automate workflows',
    description: 'Classify, score, and route. One agent, one job. Replace brittle scripts with tools that adapt when your process changes.',
    code: workflowCode,
    filename: 'lead_router.py',
  },
  {
    title: 'Build AI assistants',
    description: 'Ground agents in your knowledge base via MCP. Escalate what they cannot answer. Session memory handles the rest.',
    code: assistantCode,
    filename: 'support_agent.py',
  },
  {
    title: 'Build research agents',
    description: 'Search, synthesize, and produce a report. One agent with the right tools, not a graph of specialists.',
    code: researchCode,
    filename: 'research_agent.py',
  },
]
---

<section class="use-cases-section">
  <div class="use-cases-inner">
    {useCases.map((useCase, index) => (
      <div class="use-case">
        <div class="use-case-text">
          <span class="use-case-label">Use case {index + 1}</span>
          <h3 class="use-case-title">{useCase.title}</h3>
          <p class="use-case-description">{useCase.description}</p>
        </div>
        <div class="use-case-code">
          <CodeBlock code={useCase.code} filename={useCase.filename} />
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .use-cases-section {
    padding: 3rem 2rem 5rem;
    display: flex;
    justify-content: center;
  }

  .use-cases-inner {
    max-width: 1000px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .use-case {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 2.5rem;
    align-items: start;
  }

  .use-case:nth-child(even) {
    direction: rtl;
  }

  .use-case:nth-child(even) > * {
    direction: ltr;
  }

  .use-case-text {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .use-case-label {
    font-family: 'Figtree', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--strands-green);
  }

  .use-case-title {
    font-family: 'Figtree', sans-serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    color: var(--sl-color-white);
    margin: 0;
    letter-spacing: -0.02em;
  }

  .use-case-description {
    font-family: 'Figtree', sans-serif;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--sl-color-gray-3);
    margin: 0;
  }

  .use-case-code {
    min-width: 0;
  }

  @media (max-width: 768px) {
    .use-cases-section {
      padding: 2rem 1.5rem 3rem;
    }

    .use-case {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .use-case:nth-child(even) {
      direction: ltr;
    }

    .use-cases-inner {
      gap: 3rem;
    }
  }
</style>
