<mxfile host="app.diagrams.net" agent="Claude">
  <diagram name="Modified Agent Loop" id="modified-loop">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- EXISTING: start turn -->
        <mxCell id="10" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=14;fillColor=#e0e0e0;strokeColor=#333333;fontColor=#333333;strokeWidth=3;fontStyle=1;" value="start turn" vertex="1">
          <mxGeometry height="50" width="160" x="420" y="50" as="geometry" />
        </mxCell>

        <!-- LABEL: Decision Point A -->
        <mxCell id="LA" parent="1" style="text;html=1;fontSize=14;fontStyle=1;fontColor=#28a745;align=left;" value="Decision Point A" vertex="1">
          <mxGeometry x="660" y="150" width="150" height="30" as="geometry" />
        </mxCell>

        <!-- NEW: Decision Point A box -->
        <mxCell id="20" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=12;fillColor=#d4edda;strokeColor=#28a745;fontColor=#155724;" value="pop completed background results&#xa;and inject into conversation" vertex="1">
          <mxGeometry height="50" width="250" x="375" y="150" as="geometry" />
        </mxCell>

        <!-- EXISTING: call model -->
        <mxCell id="2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=14;fillColor=#e0e0e0;strokeColor=#999999;fontColor=#333333;" value="call model" vertex="1">
          <mxGeometry height="50" width="160" x="420" y="270" as="geometry" />
        </mxCell>

        <!-- EXISTING: tool use? -->
        <mxCell id="3" parent="1" style="rhombus;whiteSpace=wrap;html=1;fontSize=14;fillColor=#e0e0e0;strokeColor=#999999;fontColor=#333333;" value="tool use?" vertex="1">
          <mxGeometry height="80" width="110" x="445" y="380" as="geometry" />
        </mxCell>

        <!-- === LEFT SIDE: Decision Point B === -->

        <!-- LABEL: Decision Point B -->
        <mxCell id="LB" parent="1" style="text;html=1;fontSize=14;fontStyle=1;fontColor=#28a745;align=right;" value="Decision Point B" vertex="1">
          <mxGeometry x="0" y="580" width="140" height="30" as="geometry" />
        </mxCell>

        <!-- NEW: for each tool: background tool? diamond (OUTSIDE box) -->
        <mxCell id="22" parent="1" style="rhombus;whiteSpace=wrap;html=1;fontSize=12;fillColor=#d4edda;strokeColor=#28a745;fontColor=#155724;" value="&lt;b&gt;for each tool:&lt;/b&gt;&lt;br&gt;background tool?" vertex="1">
          <mxGeometry height="90" width="160" x="163" y="555" as="geometry" />
        </mxCell>

        <!-- LABEL: "per tool" above solid box -->
        <mxCell id="pertool" parent="1" style="text;html=1;fontSize=11;fontStyle=2;fontColor=#28a745;align=right;" value="per tool" vertex="1">
          <mxGeometry x="380" y="680" width="70" height="16" as="geometry" />
        </mxCell>

        <!-- SOLID GREEN BOX: wraps only the yes/no fork + two action boxes -->
        <mxCell id="group1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#28a745;strokeWidth=1.5;" value="" vertex="1">
          <mxGeometry x="30" y="698" width="430" height="100" as="geometry" />
        </mxCell>

        <!-- NEW: fork/dispatch/ACK -->
        <mxCell id="23" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=12;fillColor=#d4edda;strokeColor=#28a745;fontColor=#155724;align=left;spacingLeft=10;spacingTop=5;spacingBottom=5;" value="1. fork agent&lt;br&gt;2. dispatch background task&lt;br&gt;3. return ACK tool result" vertex="1">
          <mxGeometry height="60" width="200" x="45" y="718" as="geometry" />
        </mxCell>

        <!-- EXISTING: call tool -->
        <mxCell id="4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=14;fillColor=#e0e0e0;strokeColor=#999999;fontColor=#333333;" value="call tool" vertex="1">
          <mxGeometry height="50" width="140" x="300" y="723" as="geometry" />
        </mxCell>

        <!-- NEW: all results are ACKs? diamond -->
        <mxCell id="30" parent="1" style="rhombus;whiteSpace=wrap;html=1;fontSize=12;fillColor=#d4edda;strokeColor=#28a745;fontColor=#155724;" value="all results&#xa;are ACKs?" vertex="1">
          <mxGeometry height="70" width="130" x="178" y="870" as="geometry" />
        </mxCell>

        <!-- === RIGHT SIDE: Decision Point C === -->

        <!-- LABEL: Decision Point C -->
        <mxCell id="LC" parent="1" style="text;html=1;fontSize=14;fontStyle=1;fontColor=#28a745;align=left;" value="Decision Point C" vertex="1">
          <mxGeometry x="860" y="580" width="150" height="30" as="geometry" />
        </mxCell>

        <!-- NEW: any background tasks pending? -->
        <mxCell id="24" parent="1" style="rhombus;whiteSpace=wrap;html=1;fontSize=12;fillColor=#d4edda;strokeColor=#28a745;fontColor=#155724;" value="any background&#xa;tasks pending?" vertex="1">
          <mxGeometry height="80" width="155" x="693" y="555" as="geometry" />
        </mxCell>

        <!-- NEW: wait for next background result (shared between B all-ack and C, bold border) -->
        <mxCell id="25" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=12;fillColor=#d4edda;strokeColor=#28a745;fontColor=#155724;strokeWidth=3;" value="wait for next&#xa;background result" vertex="1">
          <mxGeometry height="50" width="155" x="480" y="880" as="geometry" />
        </mxCell>

        <!-- EXISTING: end turn -->
        <mxCell id="5" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=14;fillColor=#e0e0e0;strokeColor=#333333;fontColor=#333333;strokeWidth=3;fontStyle=1;" value="end turn" vertex="1">
          <mxGeometry height="50" width="140" x="830" y="723" as="geometry" />
        </mxCell>

        <!-- === EDGES === -->

        <mxCell id="e1" edge="1" parent="1" source="10" target="20" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#666666;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" edge="1" parent="1" source="20" target="2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#666666;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" edge="1" parent="1" source="2" target="3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#666666;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" edge="1" parent="1" source="3" target="22" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#666666;fontSize=13;fontColor=#333333;fontStyle=1;" value="yes">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" edge="1" parent="1" source="3" target="24" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#666666;fontSize=13;fontColor=#333333;fontStyle=1;" value="no">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- diamond -> yes -> fork/dispatch/ACK -->
        <mxCell id="e7" edge="1" parent="1" source="22" target="23" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#666666;fontSize=13;fontColor=#333333;fontStyle=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" value="yes">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="243" y="680" />
              <mxPoint x="145" y="680" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- diamond -> no -> call tool -->
        <mxCell id="e8" edge="1" parent="1" source="22" target="4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#666666;fontSize=13;fontColor=#333333;fontStyle=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" value="no">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="243" y="680" />
              <mxPoint x="370" y="680" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Single arrow: bottom center of green box -> all results are ACKs? -->
        <mxCell id="e20" edge="1" parent="1" style="rounded=0;strokeColor=#666666;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" source="group1" target="30">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- any bg tasks pending? -> yes -> wait (down to shared box) -->
        <mxCell id="e9" edge="1" parent="1" source="24" target="25" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#666666;fontSize=13;fontColor=#333333;fontStyle=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" value="yes">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="770" y="690" />
              <mxPoint x="680" y="690" />
              <mxPoint x="680" y="905" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- any bg tasks pending? -> no -> end turn -->
        <mxCell id="e10" edge="1" parent="1" source="24" target="5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#666666;fontSize=13;fontColor=#333333;fontStyle=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" value="no">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="770" y="690" />
              <mxPoint x="900" y="690" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- all ACKs? -> yes -> wait for next bg result -->
        <mxCell id="e22" edge="1" parent="1" source="30" target="25" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#666666;fontSize=13;fontColor=#333333;fontStyle=1;" value="yes">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- "no" label next to all-ACKs diamond left exit (in white space above the line) -->
        <mxCell id="noLabel" parent="1" style="text;html=1;fontSize=13;fontStyle=1;fontColor=#333333;align=center;" value="no" vertex="1">
          <mxGeometry x="118" y="882" width="30" height="18" as="geometry" />
        </mxCell>
        <!-- all ACKs? no -> left side loop back -->
        <mxCell id="e23" edge="1" parent="1" source="30" target="10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#666666;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="15" y="905" />
              <mxPoint x="15" y="75" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- wait for next bg result -> loop back to start turn -->
        <mxCell id="e13" edge="1" parent="1" source="25" target="10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#666666;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="558" y="970" />
              <mxPoint x="15" y="970" />
              <mxPoint x="15" y="75" />
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
